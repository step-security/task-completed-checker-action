{
  "name": "task-completed-checker-action",
  "version": "0.1.2",
  "description": "An action that checks if all tasks are completed in the pull requests.",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "pack": "ncc build",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run pack && npm test -- --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/task-completed-checker-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "step-security",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/github": "^6.0.0",
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vercel/ncc": "0.38.3",
    "eslint": "^8.57.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-github": "4.10.2",
    "eslint-plugin-i18n-text": "^1.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "29.7.0",
    "jest-circus": "29.7.0",
    "js-yaml": "3.14.2",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3"
  }
}
